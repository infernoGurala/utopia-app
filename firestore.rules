rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isParticipant(chatId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function chatExists(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId));
    }

    function isParticipantOrChatMissing(chatId) {
      return isSignedIn() &&
        (
          !chatExists(chatId) ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
    }

    function isParticipantInPendingChat(chatId) {
      return isSignedIn() &&
        request.auth.uid in getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }
    
    match /users/{uid}/memberships/{membershipId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == uid || 
        request.auth.uid in get(/databases/$(database)/documents/classes/$(membershipId)).data.writerUids
      );
    }
    
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        (request.auth.uid in resource.data.writerUids ||
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount', 'memberUids']));
      allow delete: if isSignedIn() &&
        request.auth.uid == resource.data.creatorUid;
    }

    match /attendance_cache/{uid} {
      allow read, write: if isOwner(uid);
      match /records/{rollNumber} {
        allow read, write: if isOwner(uid);
      }
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn() &&
        request.auth.uid == resource.data.uid;
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.uid;
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /app_config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /sciwordle_daily/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /sciwordle_scores/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwner(docId);
    }

    match /sciwordle_progress/{docId} {
      allow read, write: if isOwner(docId);
    }

    match /community_deletions/{docId} {
      allow read, write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read: if isParticipantOrChatMissing(chatId);
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;
      allow update: if isParticipant(chatId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipantOrChatMissing(chatId);
        allow create: if request.auth != null &&
          request.resource.data.senderId == request.auth.uid &&
          (
            isParticipant(chatId) ||
            isParticipantInPendingChat(chatId)
          );
        allow update: if isParticipant(chatId);
        allow delete: if false;
      }
    }

    // ── Follows ──────────────────────────────────────────────────────────
    match /follows/{followId} {
      // Anyone signed in can read to determine follow status
      allow read: if isSignedIn();

      // Only the follower can create a follow request
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.followerId &&
        request.resource.data.status == 'pending';

      // Only the followingId (the target) can accept (update status to 'accepted')
      // The follower can update to cancel (delete is preferred but update is allowed)
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.followingId ||
        request.auth.uid == resource.data.followerId
      );

      // Both the follower and the target can delete (unfollow / reject)
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.followerId ||
        request.auth.uid == resource.data.followingId
      );
    }

    match /universities/{docId} {
      allow read: if isSignedIn();
    }
  }
}
